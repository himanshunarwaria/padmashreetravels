# ─────────────────────────────────────────────────────────────────────────────
# Padma Shree Travels — Environment Variables
# Copy this file to .env and fill in real values for local dev.
# Set all these in Netlify → Site Settings → Environment Variables for production.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── SendGrid ──────────────────────────────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Verified sender identity in SendGrid (must be verified in SendGrid dashboard)
SENDGRID_FROM_EMAIL=travels.padamshree@gmail.com
SENDGRID_FROM_NAME=Padma Shree Travels

# Admin email to receive new booking notifications
ADMIN_NOTIFICATION_EMAIL=travels.padamshree@gmail.com

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The spreadsheet ID from the URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Name of the sheet tab where bookings are appended (default: Bookings)
GOOGLE_SHEETS_TAB_NAME=Bookings

# Service account credentials — from the JSON key file you download from Google Cloud
# GOOGLE_SERVICE_ACCOUNT_EMAIL looks like: sheets-writer@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=sheets-writer@your-project-id.iam.gserviceaccount.com

# The private key from the service account JSON — paste the full key including BEGIN/END lines.
# On Netlify, set this as a multi-line env var (paste raw, do not base64 encode).
# The \n in the example below represents actual newlines — paste the real key.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAK...\n-----END RSA PRIVATE KEY-----\n"

# ── Google Ads ────────────────────────────────────────────────────────────────
# Used in book/index.html for the gtag snippet and conversion tracking.
# Google Ads account ID format: AW-XXXXXXXXXX
GOOGLE_ADS_ID=AW-XXXXXXXXXX

# Conversion action label from Google Ads → Tools → Conversions
GOOGLE_ADS_CONVERSION_LABEL=XXXXXXXXXXXXXXXXXXXX

# ── Site ──────────────────────────────────────────────────────────────────────
SITE_URL=https://padmashreetravels.netlify.app
